{
  "name": "semantic-release-run-when",
  "version": "0.0.0",
  "description": "Conditional wrapper plugin for semantic-release",
  "packageManager": "pnpm@10.26.2",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "pnpm run lint && pnpm run test",
    "format": "biome format --write . && pnpm run format:md",
    "lint": "biome check . && pnpm run lint:md",
    "test": "node --test test/*.test.js",
    "format:md": "prettier --write \"*.md\"",
    "lint:fix": "biome check --write . && pnpm run format:md",
    "lint:md": "prettier --check \"*.md\""
  },
  "keywords": [
    "semantic-release",
    "semantic-release-plugin",
    "release",
    "conditional"
  ],
  "peerDependencies": {
    "semantic-release": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3"
  },
  "engines": {
    "node": ">=20.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ravecat/semantic-release-run-when.git"
  },
  "dependencies": {
    "@semantic-release/error": "^4.0.0"
  }
}
